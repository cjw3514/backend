generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int      @id @default(autoincrement())
  youtube_user_id String   @unique @db.VarChar(30)
  email           String
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  channels        Channel[]
  other_channels  Other_channel[]
}

model Channel {
  id                Int      @id @default(autoincrement())
  user_id           Int      @unique
  channel_name      String?  @db.VarChar(20)
  profile_image_url String?
  channel_intro     String?
  is_deleted        Boolean  @default(false)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id])
  snapshots         Channel_snapshot[]
  videos            Video[]
  other_channels    Other_channel[]
}

model Other_channel {
  id        Int    @id @default(autoincrement())
  user_id   Int
  channel_id Int

  user      User   @relation(fields: [user_id], references: [id])
  channel   Channel @relation(fields: [channel_id], references: [id])
}

model Channel_snapshot {
  id              Int      @id @default(autoincrement())
  channel_id      Int
  subscriber      Int?
  total_videos    Int?
  total_view      Int?
  channel_created DateTime?
  daily_view      Float?
  average_view    Float?
  nation          String?  @db.VarChar(2)
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())

  channel         Channel  @relation(fields: [channel_id], references: [id])
}

model Video {
  id              Int      @id @default(autoincrement())
  channel_id      Int
  video_name      String
  video_thumbnail_url String?
  video_type      Boolean
  is_deleted      Boolean  @default(false)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  channel         Channel  @relation(fields: [channel_id], references: [id])
  snapshots       Video_snapshot[]
  categories      Video_category[]
  comments        Comment[]
  comment_summaries Comment_summary[]
}

model Video_snapshot {
  id        Int      @id @default(autoincrement())
  video_id  Int
  like      Int?
  dislike   Int?
  comment   Int?
  view      Int?
  is_deleted Boolean @default(false)
  created_at DateTime @default(now())

  video     Video    @relation(fields: [video_id], references: [id])
}

model Category {
  id        Int      @id @default(autoincrement())
  category  String   @db.VarChar(20)
  created_at DateTime @default(now())

  video_categories Video_category[]
}

model Video_category {
  id         Int      @id @default(autoincrement())
  category_id Int
  video_id   Int

  category   Category @relation(fields: [category_id], references: [id])
  video      Video    @relation(fields: [video_id], references: [id])
}

model Comment {
  id           Int           @id @default(autoincrement())
  video_id     Int
  author_name  String?
  author_id    String?       @db.VarChar(30)
  content      String?
  sentiment    Sentiment?
  type         CommentType?
  status       CommentStatus?
  comment_date DateTime?
  is_parent    Boolean?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  video        Video         @relation(fields: [video_id], references: [id])
}

model Comment_summary {
  id         Int      @id @default(autoincrement())
  video_id   Int
  summary    String
  summary_type String
  sentiment  Float?
  is_deleted Boolean  @default(false)
  created_at DateTime @default(now())

  video      Video    @relation(fields: [video_id], references: [id])
}

enum Sentiment {
  positive
  negative
}

enum CommentType {
  normal
  malicious
  spam
}

enum CommentStatus {
  approved
  rejected
  deleted
}